generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// Prisma 7: niente url qui - la connessione a runtime passa dall'adapter
// (lib/prisma.ts), quella per Migrate/CLI da prisma.config.ts (DIRECT_URL).
datasource db {
  provider = "postgresql"
}

enum Ruolo {
  ALLENATORE
  ATLETA
  GENITORE
  SEGRETERIA
  DIRIGENTE
  ADMIN
}

// Non protetto da RLS (AD-9): gestibile via Prisma con connessione diretta.
// I Ruoli sono anche specchiati in app_metadata di Supabase Auth (AD-11) —
// Prisma resta la fonte di verita', app_metadata e' una cache per il Proxy.
model Utente {
  id             String           @id @default(uuid())
  supabaseAuthId String           @unique
  email          String           @unique
  attivo         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  ruoli          UtenteRuolo[]
  allenatore     Allenatore?
  genitoriAtlete GenitoreAtleta[]

  @@map("utenti")
}

// Tabella di giunzione molti-a-molti: un Utente puo' avere piu' Ruoli
// (es. un Dirigente che allena anche) - vedi ARCHITECTURE-SPINE.md ERD.
model UtenteRuolo {
  id       String @id @default(uuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  ruolo    Ruolo

  @@unique([utenteId, ruolo])
  @@map("utente_ruoli")
}

enum Sesso {
  M
  F
}

// Protetta da RLS (AD-4/AD-9): letta/scritta a runtime tramite client
// Supabase autenticato (lib/db-rls/), mai con una query Prisma diretta - a
// differenza di Utente/UtenteRuolo. Onboarding-Import e' l'unico proprietario
// dei campi identitari (AD-10) - nessun altro modulo scrive su queste colonne.
model Atleta {
  id                    String             @id @default(uuid())
  codiceFiscale         String             @unique
  nome                  String
  sesso                 Sesso
  dataNascita           DateTime
  luogoNascita          String?
  provinciaNascita      String?
  indirizzo             String?
  cap                   String?
  localitaResidenza     String?
  provinciaResidenza    String?
  categoria             String?
  matricola             String?
  dataPrimoTesseramento DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  genitori              GenitoreAtleta[]
  iscrizioni            Iscrizione[]
  certificatoMedico     CertificatoMedico?
  gruppi                GruppoAtleta[]
  presenze              Presenza[]
  notifiche             Notifica[]
  misurazioni           MisurazioneAtleta[]

  @@map("atlete")
}

// Story 6.1 (FR-24): protetta da RLS (dato personale nel tempo) - bind-list
// deliberatamente piu' stretto delle altre tabelle RLS di questo progetto:
// solo ALLENATORE (proprie Atlete) e ATLETA (se stessa), nessun accesso
// Admin/Dirigente/Segreteria (fedele al testo letterale di FR-24, decisione
// deliberata vedi Dev Notes Story 6.1). Log append-only: nessun AC richiede
// modifica/eliminazione di una misurazione passata. `data` come stringa
// "YYYY-MM-DD" (non DateTime) - stesso principio di Presenza.data/
// Slot.oraInizio, nessuna aritmetica di date richiesta. `tipo`/`unitaMisura`
// stringhe libere (es. "Altezza"/"cm"), non un enum chiuso - FR-24 parla di
// esempi, non di un elenco esaustivo.
model MisurazioneAtleta {
  id          String   @id @default(uuid())
  atletaId    String
  atleta      Atleta   @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  tipo        String
  valore      Float
  unitaMisura String
  data        String
  createdAt   DateTime @default(now())

  @@map("misurazioni_atleta")
}

// Non protetta da RLS (AD-9, elencata esplicitamente insieme a Palestra,
// Campo, Slot, Gruppo, Utente, UtenteRuolo) - gestibile via Prisma diretto,
// a differenza di Atleta. `utenteId` e' null finche' la persona non si
// registra con lo stesso Codice Fiscale (Story 1.1 registrati/actions.ts) -
// l'aggancio lo valorizza, nessun record duplicato.
model Allenatore {
  id            String             @id @default(uuid())
  nome          String
  codiceFiscale String             @unique
  utenteId      String?            @unique
  utente        Utente?            @relation(fields: [utenteId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  gruppi        GruppoAllenatore[]

  @@map("allenatori")
}

// Tabella di giunzione molti-a-molti (ERD: GENITORE }o--o{ ATLETA). Non
// protetta da RLS (non nel bind-list di AD-4) - gestita via Prisma diretto
// come UtenteRuolo/Allenatore (AD-9), anche se ha una FK verso Atleta
// (RLS-protetta): il vincolo di integrita' referenziale e' una garanzia
// Postgres indipendente dalla RLS/PostgREST.
// `autoAggancio` (Story 3.2, review fix): distingue un aggancio "a se
// stessa" (Story 2.7, Ruolo Atleta che si registra) da un aggancio
// Genitore<->figlia - una riga con lo stesso utenteId puo' essere di
// entrambi i tipi (es. un'atleta maggiorenne che e' anche genitore di
// un'altra atleta, gia' testato in registrati/actions.test.ts) e nulla
// prima d'ora distingueva le due relazioni. Necessario perche' la policy
// RLS `atleta_propria_select` su "presenze" (Story 3.2) deve concedere
// lettura SOLO per l'Atleta a cui l'Utente e' agganciato come se stessa,
// mai per una figlia - senza questa colonna, un Utente con doppio Ruolo
// Atleta+Genitore otterrebbe accesso allo storico presenze della figlia.
model GenitoreAtleta {
  id            String   @id @default(uuid())
  utenteId      String
  atletaId      String
  autoAggancio  Boolean  @default(false)
  utente        Utente   @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  atleta        Atleta   @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([utenteId, atletaId])
  @@map("genitori_atlete")
}

// Non protetta da RLS: non e' nel bind-list di AD-4, e' dato puramente
// strutturale (intervallo di date), non personale/sensibile - stesso
// trattamento di Palestra/Campo/Slot/Gruppo (AD-9). Gestita via Prisma
// diretto tramite lib/anno-agonistico/ (Structural Seed).
model AnnoAgonistico {
  id           String         @id @default(uuid())
  dataInizio   DateTime
  dataFine     DateTime
  createdAt    DateTime       @default(now())
  iscrizioni   Iscrizione[]
  gruppi       Gruppo[]
  gruppoAtlete GruppoAtleta[]

  @@unique([dataInizio, dataFine])
  @@map("anni_agonistici")
}

// Protetta da RLS (AD-4/AD-9, esplicitamente nel bind-list): letta/scritta a
// runtime tramite client Supabase autenticato (lib/db-rls/iscrizione.ts),
// mai con una query Prisma diretta - come Atleta (Story 1.3). Una sola
// Iscrizione per Atleta per Anno Agonistico (non un vincolo su atletaId da
// solo: un'Atleta ha un'Iscrizione per ogni stagione in cui si iscrive).
model Iscrizione {
  id               String         @id @default(uuid())
  atletaId         String
  annoAgonisticoId String
  atleta           Atleta         @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  annoAgonistico   AnnoAgonistico @relation(fields: [annoAgonisticoId], references: [id], onDelete: Cascade)
  confermataIl     DateTime       @default(now())
  createdAt        DateTime       @default(now())
  // Story 1.8: false = esclusa manualmente (o mai confermata) - non
  // eliminata, per non riaprire la rimozione del DELETE decisa in Story 1.6.
  attiva           Boolean        @default(true)

  @@unique([atletaId, annoAgonisticoId])
  @@map("iscrizioni")
}

// Protetta da RLS (AD-4/AD-9, esplicitamente nel bind-list): letta/scritta a
// runtime tramite client Supabase autenticato (lib/db-rls/certificato-medico.ts),
// mai con una query Prisma diretta - come Atleta/Iscrizione. Un solo
// Certificato "corrente" per Atleta (non uno storico multi-riga per import -
// vedi Dev Notes Story 1.7): atletaId univoco.
// `dataFineValidita` (Story 4.1: da obbligatoria a opzionale) - il flusso di
// import (Story 1.7, unisciCertificato) continua a fornirla sempre; il nuovo
// flusso di upload (Story 4.1) crea/aggiorna solo `filePath`, lasciando la
// validazione della data alla Segreteria (Story 4.4) - un Certificato
// caricato ma non ancora confermato ha quindi `dataFineValidita = null`
// ("in attesa di validazione" implicito, nessun enum di stato introdotto qui,
// prematuro prima di Story 4.4).
// `filePath` (Story 4.1): percorso nel bucket Storage privato
// "certificati-medici" (AD-6), mai un URL - l'accesso avviene solo tramite
// URL firmati a scadenza breve generati on-demand (lib/storage/certificati.ts),
// mai un valore pre-generato e persistito.
model CertificatoMedico {
  id                 String           @id @default(uuid())
  atletaId           String           @unique
  atleta             Atleta           @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  dataInizioValidita DateTime?
  dataFineValidita   DateTime?
  mesiValidita       Int?
  modulo             String?
  filePath           String?
  stato              StatoCertificato @default(CONFERMATO)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("certificati_medici")
}

// Story 4.4 (FR-14): IN_ATTESA quando caricato da Genitore/Atleta e non
// ancora verificato da un umano (Story 4.1, nessuna data di validita'
// ancora); CONFERMATO quando la Segreteria/Admin/Dirigente ha verificato le
// date (o le ha inserite manualmente per un certificato ricevuto fuori app).
// Default CONFERMATO a livello di colonna: corretto per le righe che
// arrivano dall'import federale (Story 1.3/1.7, gia' dati fidati) - il
// percorso di solo upload (Story 4.1, collegaFileCertificato) sovrascrive
// esplicitamente con IN_ATTESA ad ogni caricamento.
enum StatoCertificato {
  IN_ATTESA
  CONFERMATO
}

// Story 4.2 (FR-12): protetta da RLS - rivela quale Atleta ha avuto un
// evento di caricamento certificato, visibile solo ad Allenatore (proprio
// Gruppo) e Dirigente (accesso ampio). Deliberatamente minimale: nessun
// campo "letta"/stato (nessun AC lo richiede) e nessun campo "messaggio"/
// "tipo" (un solo evento possibile oggi - nome Atleta e data si ricavano a
// lettura via join applicativo, mai un `include` Prisma diretto su questa
// tabella RLS-protetta).
model Notifica {
  id        String   @id @default(uuid())
  atletaId  String
  atleta    Atleta   @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("notifiche")
}

// Story 7.1 (FR-31, AD-12): riga singola (nessuna business key naturale -
// il modulo dati legge "la prima riga esistente" e fa update-se-esiste/
// insert-se-assente). Protetta da RLS (AD-9 esteso), ADMIN-only per ogni
// operazione - contiene una password SMTP salvata in chiaro, scelta
// deliberata coerente col resto del progetto (nessuna cifratura
// applicativa, protezione solo RLS, vedi AD-12). `sicura` distingue SSL
// implicito (tipicamente porta 465) da STARTTLS (tipicamente porta 587) -
// necessario perche' Nodemailer lo richiede esplicitamente per creare il
// transporter corretto.
model ConfigurazioneSmtp {
  id           String   @id @default(uuid())
  host         String
  porta        Int
  sicura       Boolean  @default(true)
  utente       String
  password     String
  mittente     String
  nomeMittente String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("configurazione_smtp")
}

// Non protetta da RLS (AD-9, elencata esplicitamente insieme a Campo/Slot/
// Gruppo/Allenatore) - gestibile via Prisma diretto, come Allenatore
// (Story 1.4) e AnnoAgonistico (Story 1.6). Struttura permanente, nessun
// riferimento all'Anno Agonistico (a differenza di Gruppo/Iscrizione, AD-8).
model Palestra {
  id        String   @id @default(uuid())
  nome      String
  indirizzo String?
  createdAt DateTime @default(now())
  campi     Campo[]

  @@map("palestre")
}

// Non protetta da RLS (AD-9), stesso trattamento di Palestra. Una palestra
// con piu' Campi puo' ospitare due Gruppi in contemporanea sullo stesso
// orario, su Campi diversi (AC #4) - nessun vincolo qui lo impedisce; la
// gestione dei conflitti sugli Slot e' fuori scope (Story 2.5).
model Campo {
  id         String   @id @default(uuid())
  nome       String
  palestraId String
  palestra   Palestra @relation(fields: [palestraId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  slot       Slot[]

  @@map("campi")
}

// Non protetto da RLS (AD-9, elencato esplicitamente insieme a Palestra/
// Campo/Slot/Allenatore) - gestibile via Prisma diretto. AD-8: FK diretta
// verso AnnoAgonistico (nessun onDelete esplicito diverso dal default
// Restrict di Prisma - nessuna UI di eliminazione Anno Agonistico esiste).
// Nessuna relazione con Palestra/Campo/Atleta in questa storia: quei
// collegamenti sono proprieta' di storie successive (2.4, 2.5). La
// relazione con Allenatore (molti-a-molti, tramite GruppoAllenatore) e'
// stata aggiunta in Story 2.3.
model Gruppo {
  id               String             @id @default(uuid())
  nome             String
  categoria        String
  annoAgonisticoId String
  annoAgonistico   AnnoAgonistico     @relation(fields: [annoAgonisticoId], references: [id])
  createdAt        DateTime           @default(now())
  allenatori       GruppoAllenatore[]
  atlete           GruppoAtleta[]
  slot             Slot[]
  visibileDirigente GruppoVisibileDirigente?

  @@map("gruppi")
}

// Story 5.2 (FR-27): permesso granulare per Gruppo, solo per il Ruolo
// Dirigente - Admin/Segreteria restano sempre ad accesso pieno (decisione
// esplicita, non configurabile). Non protetta da RLS (AD-9, stesso
// trattamento di Gruppo/Slot - dato puramente strutturale, nessun GRANT
// verso "authenticated"): la policy RLS su certificati_medici la legge
// tramite la funzione SECURITY DEFINER "dirigente_vede_certificato_atleta"
// (stesso pattern di "allenatore_possiede_atleta", Story 3.1/4.5). Nessuna
// riga per un Gruppo = quel Gruppo non e' nella lista; tabella
// completamente vuota = nessuna restrizione attiva (comportamento di oggi).
model GruppoVisibileDirigente {
  id        String   @id @default(uuid())
  gruppoId  String   @unique
  gruppo    Gruppo   @relation(fields: [gruppoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("gruppi_visibili_dirigente")
}

// Tabella di giunzione molti-a-molti (ERD: GRUPPO }o--o{ ALLENATORE). Non
// protetta da RLS (AD-9: ne' Gruppo ne' Allenatore sono nel bind-list di
// AD-4) - gestita via Prisma diretto, stesso pattern di GenitoreAtleta
// (Story 1.5) e UtenteRuolo (Story 1.1). @@unique rende l'assegnazione
// idempotente (AC #3, Story 2.3): un tentativo di duplicato viola il
// vincolo (Prisma P2002), trattato come successo invece di un
// check-then-insert che lascerebbe una finestra di race.
model GruppoAllenatore {
  id           String     @id @default(uuid())
  gruppoId     String
  allenatoreId String
  gruppo       Gruppo     @relation(fields: [gruppoId], references: [id], onDelete: Cascade)
  allenatore   Allenatore @relation(fields: [allenatoreId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([gruppoId, allenatoreId])
  @@map("gruppo_allenatori")
}

// Tabella di giunzione (ERD: GRUPPO ||--o{ ATLETA). Non protetta da RLS
// (AD-9), stesso principio di GenitoreAtleta (Story 1.5): la FK verso
// Atleta (RLS-protetta, AD-4) e' solo un vincolo di integrita' referenziale
// Postgres, indipendente da RLS/PostgREST - nessuna lettura delle colonne
// di Atleta deve mai passare da qui (vedi Dev Notes Story 2.4, usare
// elencaAtlete via client Supabase autenticato, mai un include Prisma).
// annoAgonisticoId e' denormalizzato dal Gruppo assegnato (non risolto
// autonomamente) - e' l'unico modo per esprimere a livello DB il vincolo
// "un'Atleta ha un solo Gruppo per Anno Agonistico" (AC #2): un @@unique
// non puo' riferirsi a una colonna di Gruppo. Stesso principio di
// Iscrizione (FK diretta a AnnoAgonistico sulla stessa riga), non il
// pattern transitivo di Slot/Presenza.
model GruppoAtleta {
  id               String         @id @default(uuid())
  atletaId         String
  gruppoId         String
  annoAgonisticoId String
  gruppo           Gruppo         @relation(fields: [gruppoId], references: [id], onDelete: Cascade)
  atleta           Atleta         @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  annoAgonistico   AnnoAgonistico @relation(fields: [annoAgonisticoId], references: [id])
  createdAt        DateTime       @default(now())

  @@unique([atletaId, annoAgonisticoId])
  @@map("gruppo_atlete")
}

enum GiornoSettimana {
  LUNEDI
  MARTEDI
  MERCOLEDI
  GIOVEDI
  VENERDI
  SABATO
  DOMENICA
}

// Non protetto da RLS (AD-9, elencato esplicitamente insieme a Palestra/
// Campo/Gruppo/Allenatore) - gestibile via Prisma diretto, come Campo/Gruppo.
// AD-2: Orari-Palestre e' l'unico proprietario della mutazione di Slot,
// incluso il suo FK verso Gruppo - Gruppi-Allenatori lo legge (per popolare
// i propri form) ma non lo scrive mai. AD-8: nessuna colonna
// annoAgonisticoId propria - a differenza di Iscrizione/GruppoAtleta (FK
// diretta, serviva un vincolo di unicita' reale), Slot eredita l'Anno
// Agonistico transitivamente tramite Gruppo (nessun vincolo di unicita'
// analogo da esprimere qui). oraInizio/oraFine sono String ("HH:MM"), non
// DateTime/@db.Time: nessuna aritmetica su orari richiesta in questa storia
// (AC #1, "nessuna rilevazione conflitti in continuo richiesta") - un tipo
// data/ora introdurrebbe solo l'ambiguita' di fuso orario gia' incontrata
// con AnnoAgonistico (Story 1.6) senza alcun beneficio.
model Slot {
  id        String          @id @default(uuid())
  giorno    GiornoSettimana
  oraInizio String
  oraFine   String
  campoId   String
  campo     Campo           @relation(fields: [campoId], references: [id], onDelete: Cascade)
  gruppoId  String
  gruppo    Gruppo          @relation(fields: [gruppoId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  presenze  Presenza[]

  @@map("slot")
}

// Protetta da RLS (AD-4/AD-9, esplicitamente nel bind-list): letta/scritta a
// runtime tramite client Supabase autenticato (lib/db-rls/presenza.ts), mai
// con una query Prisma diretta - come Atleta/Iscrizione/CertificatoMedico.
// AD-8: nessuna colonna annoAgonisticoId propria, eredita la stagione
// transitivamente tramite Slot -> Gruppo (stesso principio di Slot stesso).
// `data` e' String "YYYY-MM-DD" (non DateTime/@db.Date), stesso motivo di
// Slot.oraInizio/oraFine (Story 2.5): nessuna aritmetica sulle date
// richiesta da questa storia, un tipo data/ora introdurrebbe solo
// l'ambiguita' di fuso orario gia' incontrata con AnnoAgonistico.
// Prima policy RLS di questa codebase con scoping relazionale (non solo per
// Ruolo): l'Allenatore puo' scrivere/leggere solo per i Gruppi di cui e'
// allenatore (AC #4, Story 3.1) - vedi la migrazione per il dettaglio SQL.
// @@unique rende la registrazione idempotente (AC #3): un upsert su questa
// chiave aggiorna la riga esistente invece di duplicarla.
model Presenza {
  id        String   @id @default(uuid())
  atletaId  String
  slotId    String
  data      String
  presente  Boolean
  atleta    Atleta   @relation(fields: [atletaId], references: [id], onDelete: Cascade)
  slot      Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([atletaId, slotId, data])
  @@map("presenze")
}
