# Copia questo file in .env (per Supabase locale, `supabase start` stampa questi valori).

# Connessione runtime (Supavisor transaction pooler, ?pgbouncer=true) - usata da PrismaClient.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?pgbouncer=true"
# Connessione diretta (non pooled) - usata solo dal CLI Prisma (migrate) in prisma.config.ts.
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Da `supabase start` (locale) o dal progetto Supabase (regione EU, produzione).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Segreto condiviso col chiamante schedulato esterno (Cron) - protegge
# app/api/cron/promemoria-certificati, l'unico endpoint pubblicamente
# raggiungibile senza sessione Supabase Auth (Story 4.6, FR-16).
CRON_SECRET=""
